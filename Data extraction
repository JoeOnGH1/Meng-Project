  69.66  -87.43   82.60  110.35  139.76  1398.02\n","\n","Day-ahead sample:\n","                  timestamp  price_eur_mwh   season    market\n","0 2022-09-30 22:00:00+00:00          64.41  2022/23  dayahead\n","1 2022-09-30 22:15:00+00:00         110.86  2022/23  dayahead\n","2 2022-09-30 22:30:00+00:00          70.08  2022/23  dayahead\n","3 2022-09-30 22:45:00+00:00          19.54  2022/23  dayahead\n","4 2022-09-30 23:00:00+00:00         109.19  2022/23  dayahead\n"]}],"source":["#This code is responsible for extracting entso and smard data using an api key\"\n","\n","\n","import requests\n","import xml.etree.ElementTree as ET\n","import pandas as pd\n","from datetime import datetime\n","from dateutil.relativedelta import relativedelta\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","\n","API_KEY = \"[REDACTED]\"\n","BASE_URL = \"https://web-api.tp.entsoe.eu/api\"\n","DOMAIN = \"10Y1001A1001A82H\"\n","\n","def download_prices(start_str, end_str, market_type=\"dayahead\"):\n","    start = datetime.strptime(start_str, \"%Y%m%d%H%M\")\n","    end = datetime.strptime(end_str, \"%Y%m%d%H%M\")\n","\n","    all_rows = []\n","    chunk_start = start\n","\n","    while chunk_start < end:\n","        chunk_end = min(chunk_start + relativedelta(months=1), end)\n","\n","        params = {\n","            \"securityToken\": API_KEY,\n","            \"documentType\": \"A44\",\n","            \"in_Domain\": DOMAIN,\n","            \"out_Domain\": DOMAIN,\n","            \"periodStart\": chunk_start.strftime(\"%Y%m%d%H%M\"),\n","            \"periodEnd\": chunk_end.strftime(\"%Y%m%d%H%M\"),\n","        }\n","\n","        if market_type == \"intraday_A05\":\n","            params[\"contract_MarketAgreement.Type\"] = \"A05\"\n","        elif market_type == \"intraday_A07\":\n","            params[\"contract_MarketAgreement.Type\"] = \"A07\"\n","\n","\n","        r = requests.get(BASE_URL, params=params)\n","\n","        if r.status_code != 200:\n","            print(f\"  HTTP Error {r.status_code} for {chunk_start.strftime('%Y-%m')}\")\n","            print(f\"  Response: {r.text[:300]}\")\n","            chunk_start = chunk_end\n","            continue\n","\n","        root = ET.fromstring(r.content)\n","        ns = {\"ns\": root.tag.split(\"}\")[0].strip(\"{\")}\n","\n","        reason = root.find(\".//ns:Reason/ns:text\", ns)\n","        if reason is not None:\n","            print(f\"  API message for {chunk_start.strftime('%Y-%m')}: {reason.text}\")\n","            chunk_start = chunk_end\n","            continue\n","\n","        chunk_rows = 0\n","        for ts in root.findall(\".//ns:TimeSeries\", ns):\n","            for period in ts.findall(\".//ns:Period\", ns):\n","                start_node = period.find(\".//ns:timeInterval/ns:start\", ns)\n","                if start_node is None:\n","                    continue\n","\n","                period_start = datetime.fromisoformat(\n","                    start_node.text.replace(\"Z\", \"+00:00\")\n","                )\n","\n","                resolution = period.find(\"ns:resolution\", ns).text\n","                if resolution == \"PT60M\":\n","                    step = pd.Timedelta(hours=1)\n","                elif resolution == \"PT15M\":\n","                    step = pd.Timedelta(minutes=15)\n","                else:\n","                    step = pd.Timedelta(hours=1)\n","\n","                for point in period.findall(\"ns:Point\", ns):\n","                    position = int(point.find(\"ns:position\", ns).text)\n","                    price_node = point.find(\"ns:price.amount\", ns)\n","                    if price_node is None:\n","                        continue\n","                    price = float(price_node.text)\n","                    timestamp = period_start + (position - 1) * step\n","                    all_rows.append([timestamp, price])\n","                    chunk_rows += 1\n","\n","        print(f\"  ✓ {chunk_start.strftime('%Y-%m')} — {chunk_rows} new rows — {len(all_rows)} total\")\n","        chunk_start = chunk_end\n","\n","    if not all_rows:\n","        print(f\"  WARNING: No data returned for market_type={market_type}\")\n","        return pd.DataFrame(columns=[\"timestamp\", \"price_eur_mwh\"])\n","\n","    df = pd.DataFrame(all_rows, columns=[\"timestamp\", \"price_eur_mwh\"])\n","    df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"], utc=True)\n","    df = df.sort_values(\"timestamp\").drop_duplicates(\"timestamp\").reset_index(drop=True)\n","    return df\n","\n","\n","def filter_trading_window(df):\n","    \"\"\"Keep only 11:30-23:30 UTC\"\"\"\n","    if df.empty:\n","        return df\n","    return df[df[\"timestamp\"].dt.hour.between(11, 23)].reset_index(drop=True)\n","\n","\n","# -------------------------\n","# Winter seasons only\n","# -------------------------\n","winter_ranges = [\n","    (\"202210010000\", \"202302280000\"),   # Winter 22/23  → training\n","    (\"202310010000\", \"202402290000\"),   # Winter 23/24  → training\n","    (\"202410010000\", \"202502280000\"),   # Winter 24/25  → test set\n","]\n","\n","# -------------------------\n","# Day-ahead prices\n","# -------------------------\n","print(\"=\" * 50)\n","print(\"DOWNLOADING DAY-AHEAD PRICES\")\n","print(\"=\" * 50)\n","\n","dayahead_frames = []\n","for start, end in winter_ranges:\n","    print(f\"\\n--- Day-ahead {start[:6]} to {end[:6]} ---\")\n","    df = download_prices(start, end, market_type=\"dayahead\")\n","    df[\"season\"] = f\"{start[:4]}/{str(int(start[:4])+1)[2:]}\"\n","    dayahead_frames.append(df)\n","\n","dayahead = pd.concat(dayahead_frames).reset_index(drop=True)\n","dayahead = filter_trading_window(dayahead)\n","dayahead[\"market\"] = \"dayahead\"\n","\n","\n","\n","# -------------------------\n","# Summary\n","# -------------------------\n","print(\"\\n\" + \"=\" * 50)\n","print(\"SUMMARY\")\n","print(\"=\" * 50)\n","print(f\"Day-ahead rows:  {len(dayahead)}\")\n","\n","\n","print(\"\\nDay-ahead by season:\")\n","if not dayahead.empty:\n","    print(dayahead.groupby(\"season\")[\"price_eur_mwh\"].describe().round(2))\n","\n","\n","print(\"\\nDay-ahead sample:\")\n","print(dayahead.head())\n","\n","# -------------------------\n","# Save to CSV\n","# -------------------------\n","dayahead.to_csv(\"/content/drive/MyDrive/MEng Project/dayahead_prices.csv\", index=False)\n","\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0oKoWxFCbD-U","executionInfo":{"status":"ok","timestamp":1772886671458,"user_tz":0,"elapsed":195588,"user":{"displayName":"Joe","userId":"01412925045909520526"}},"outputId":"6e36028c-f0ae-478d-e35c-8cb1d1fcad74"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","=======================================================\n","DOWNLOADING SMARD FUNDAMENTALS (targeted)\n","=======================================================\n","\n","--- wind_onshore_mw (filter 4067) ---\n","  Chunks available: 584 — downloading 127 relevant chunks\n","  Raw rows in window: 84577\n","  After trading window filter: 23556 rows\n","  Date range: 2022-10-01 11:00:00+00:00 → 2025-02-27 23:45:00+00:00\n","\n","--- wind_offshore_mw (filter 1225) ---\n","  Chunks available: 584 — downloading 127 relevant chunks\n","  Raw rows in window: 84577\n","  After trading window filter: 23556 rows\n","  Date range: 2022-10-01 11:00:00+00:00 → 2025-02-27 23:45:00+00:00\n","\n","--- load_mw (filter 410) ---\n","  Chunks available: 584 — downloading 127 relevant chunks\n","  Raw rows in window: 84577\n","  After trading window filter: 23556 rows\n","  Date range: 2022-10-01 11:00:00+00:00 → 2025-02-27 23:45:00+00:00\n","\n","=======================================================\n","MERGING\n","=======================================================\n","Merged rows:  23556\n","Date range:   2022-10-01 11:00:00+00:00 → 2025-02-27 23:45:00+00:00\n","\n","Missing values:\n","timestamp           0\n","season              0\n","wind_onshore_mw     0\n","wind_offshore_mw    0\n","load_mw             0\n","wind_total_mw       0\n","dtype: int64\n","\n","=======================================================\n","SUMMARY BY SEASON\n","=======================================================\n","        wind_onshore_mw                                                         wind_offshore_mw                                                    wind_total_mw                                                         load_mw                                                             \n","                  count    mean     std    min     25%     50%     75%      max            count   mean    std   min    25%     50%     75%     max         count    mean     std    min     25%     50%     75%      max   count     mean     std     min      25%      50%      75%      max\n","season                                                                                                                                                                                                                                                                                        \n","2022/23          7852.0  3668.1  2698.2   84.2  1459.4  3014.0  5218.6  11320.0           7852.0  870.6  462.2   0.0  480.4   953.1  1263.1  1812.2        7852.0  4538.7  2938.5  250.8  2009.2  4101.4  6485.0  12614.2  7852.0  14242.3  1948.4  8989.8  12696.2  14317.1  15949.2  17834.0\n","2023/24          7904.0  4915.1  2899.5  121.5  2490.8  4545.0  6959.9  12126.0           7904.0  950.1  461.9  17.8  559.4  1032.4  1337.1  1831.2        7904.0  5865.2  3137.8  247.0  3257.2  5671.4  8103.5  13230.0  7904.0  14537.9  2063.8  8730.0  12914.5  14654.0  16312.6  18756.5\n","2024/25          7800.0  3660.6  2824.7   10.5  1289.6  2899.0  5713.8  11426.8           7800.0  826.5  499.3   0.0  382.5   862.6  1247.5  1993.2        7800.0  4487.1  3105.6   10.5  1791.9  3926.6  6829.4  12412.5  7800.0  14655.8  2039.3  8940.0  13142.3  14652.5  16443.5  18747.0\n","\n","✓ Saved to smard_fundamentals.csv\n","                  timestamp   season  wind_onshore_mw  wind_offshore_mw  \\\n","0 2022-10-01 11:00:00+00:00  2022/23          7111.50           1262.00   \n","1 2022-10-01 11:15:00+00:00  2022/23          6985.25           1240.25   \n","2 2022-10-01 11:30:00+00:00  2022/23          7059.00           1206.00   \n","3 2022-10-01 11:45:00+00:00  2022/23          7025.25           1221.00   \n","4 2022-10-01 12:00:00+00:00  2022/23          6889.50           1235.50   \n","\n","    load_mw  wind_total_mw  \n","0  14012.25        8373.50  \n","1  13846.50        8225.50  \n","2  13743.75        8265.00  \n","3  13603.50        8246.25  \n","4  13549.75        8125.00  \n"]}],"source":["import requests\n","import pandas as pd\n","from datetime import datetime, timezone\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","\n","SMARD_BASE = \"https://www.smard.de/app/chart_data\"\n","\n","FILTERS = {\n","    \"wind_onshore_mw\":  4067,\n","    \"wind_offshore_mw\": 1225,\n","    \"load_mw\":          410,\n","}\n","\n","REGION     = \"DE\"\n","RESOLUTION = \"quarterhour\"\n","\n","# Only the three winters we need\n","SEASON_START = datetime(2022, 10, 1,  tzinfo=timezone.utc)\n","SEASON_END   = datetime(2025,  2, 28, tzinfo=timezone.utc)\n","\n","\n","def fetch_smard_filtered(filter_id: int, region: str = \"DE\", resolution: str = \"quarterhour\") -> pd.DataFrame:\n","    \"\"\"\n","    Download SMARD data but skip any chunks that fall entirely outside\n","    the Oct 2022 - Feb 2025 window before even requesting them.\n","    \"\"\"\n","    index_url = f\"{SMARD_BASE}/{filter_id}/{region}/index_{resolution}.json\"\n","    r = requests.get(index_url, timeout=30)\n","    r.raise_for_status()\n","    all_timestamps = r.json().get(\"timestamps\", [])\n","\n","    one_week_ms     = 7 * 24 * 3600 * 1000\n","    season_start_ms = int(SEASON_START.timestamp() * 1000)\n","    season_end_ms   = int(SEASON_END.timestamp()   * 1000)\n","\n","    relevant = [\n","        ts for ts in all_timestamps\n","        if ts < season_end_ms and (ts + one_week_ms) > season_start_ms\n","    ]\n","\n","    print(f\"  Chunks available: {len(all_timestamps)} — downloading {len(relevant)} relevant chunks\")\n","\n","    all_rows = []\n","\n","    for ts in relevant:\n","        url = f\"{SMARD_BASE}/{filter_id}/{region}/{filter_id}_{region}_{resolution}_{ts}.json\"\n","        try:\n","            resp = requests.get(url, timeout=30)\n","            resp.raise_for_status()\n","            data = resp.json()\n","        except Exception as e:\n","            print(f\"  WARNING: Failed chunk {ts}: {e}\")\n","            continue\n","\n","        for point in data.get(\"series\", []):\n","            if point is None or len(point) < 2 or point[1] is None:\n","                continue\n","            epoch_ms, value = point[0], point[1]\n","            if epoch_ms < season_start_ms or epoch_ms > season_end_ms:\n","                continue\n","            ts_utc = datetime.fromtimestamp(epoch_ms / 1000, tz=timezone.utc)\n","            all_rows.append([ts_utc, float(value)])\n","\n","    if not all_rows:\n","        return pd.DataFrame(columns=[\"timestamp\", \"value\"])\n","\n","    df = pd.DataFrame(all_rows, columns=[\"timestamp\", \"value\"])\n","    df = df.sort_values(\"timestamp\").drop_duplicates(\"timestamp\").reset_index(drop=True)\n","    return df\n","\n","\n","def filter_winter_trading_window(df: pd.DataFrame) -> pd.DataFrame:\n","    \"\"\"Keep winter months (Oct-Feb) and trading window (11:00-23:59 UTC)\"\"\"\n","    if df.empty:\n","        return df\n","    month     = df[\"timestamp\"].dt.month\n","    in_winter = month.isin([10, 11, 12, 1, 2])\n","    in_window = df[\"timestamp\"].dt.hour.between(11, 23)\n","    return df[in_winter & in_window].reset_index(drop=True)\n","\n","\n","def assign_season(ts: pd.Series) -> pd.Series:\n","    month        = ts.dt.month\n","    year         = ts.dt.year\n","    season_start = year.where(month >= 10, year - 1)\n","    return season_start.astype(str) + \"/\" + (season_start + 1).astype(str).str[-2:]\n","\n","\n","# ─────────────────────────────────────────────\n","# Download\n","# ─────────────────────────────────────────────\n","print(\"=\" * 55)\n","print(\"DOWNLOADING SMARD FUNDAMENTALS (targeted)\")\n","print(\"=\" * 55)\n","\n","smard_frames = {}\n","\n","for col_name, filter_id in FILTERS.items():\n","    print(f\"\\n--- {col_name} (filter {filter_id}) ---\")\n","\n","    df = fetch_smard_filtered(filter_id, region=REGION, resolution=RESOLUTION)\n","    print(f\"  Raw rows in window: {len(df)}\")\n","\n","    df = filter_winter_trading_window(df)\n","    df = df.rename(columns={\"value\": col_name})\n","    df[\"season\"] = assign_season(df[\"timestamp\"])\n","\n","    print(f\"  After trading window filter: {len(df)} rows\")\n","    print(f\"  Date range: {df['timestamp'].min()} → {df['timestamp'].max()}\")\n","\n","    smard_frames[col_name] = df\n","\n","# ─────────────────────────────────────────────\n","# Merge\n","# ─────────────────────────────────────────────\n","print(\"\\n\" + \"=\" * 55)\n","print(\"MERGING\")\n","print(\"=\" * 55)\n","\n","merged = smard_frames[\"wind_onshore_mw\"][[\"timestamp\", \"season\", \"wind_onshore_mw\"]]\n","\n","for col_name in [\"wind_offshore_mw\", \"load_mw\"]:\n","    merged = merged.merge(\n","        smard_frames[col_name][[\"timestamp\", col_name]],\n","        on=\"timestamp\", how=\"outer\"\n","    )\n","\n","merged = merged.sort_values(\"timestamp\").reset_index(drop=True)\n","merged[\"wind_total_mw\"] = merged[\"wind_onshore_mw\"] + merged[\"wind_offshore_mw\"]\n","\n","print(f\"Merged rows:  {len(merged)}\")\n","print(f\"Date range:   {merged['timestamp'].min()} → {merged['timestamp'].max()}\")\n","print(f\"\\nMissing values:\\n{merged.isnull().sum()}\")\n","\n","# ─────────────────────────────────────────────\n","# Summary\n","# ─────────────────────────────────────────────\n","print(\"\\n\" + \"=\" * 55)\n","print(\"SUMMARY BY SEASON\")\n","print(\"=\" * 55)\n","print(merged.groupby(\"season\")[[\"wind_onshore_mw\", \"wind_offshore_mw\", \"wind_total_mw\", \"load_mw\"]].describe().round(1).to_string())\n","\n","# ─────────────────────────────────────────────\n","# Save\n","# ─────────────────────────────────────────────\n","merged.to_csv(\"/content/drive/MyDrive/MEng Project/smard_fundamentals.csv\", index=False)\n","print(\"\\n✓ Saved to smard_fundamentals.csv\")\n","print(merged.head())"]},{"cell_type":"code","source":["import pandas as pd\n","import matplotlib.pyplot as plt\n","import matplotlib.dates as mdates\n","\n","# ─────────────────────────────────────────────\n","# Load\n","# ─────────────────────────────────────────────\n","da = pd.read_csv(\"/content/drive/MyDrive/MEng Project/dayahead_prices.csv\", parse_dates=[\"timestamp\"])\n","sm = pd.read_csv(\"/content/drive/MyDrive/MEng Project/smard_fundamentals.csv\", parse_dates=[\"timestamp\"])\n","\n","# ─────────────────────────────────────────────\n","# Clean — drop obsolete columns\n","# ─────────────────────────────────────────────\n","da = da.drop(columns=[\"market\"])           # redundant — everything is day-ahead\n","sm = sm.drop(columns=[\"wind_offshore_mw\"]) # excluded from model (using wind_total_mw)\n","\n","# ─────────────────────────────────────────────\n","# Merge on timestamp\n","# ─────────────────────────────────────────────\n","df = da.merge(\n","    sm[[\"timestamp\", \"wind_onshore_mw\", \"wind_total_mw\", \"load_mw\"]],\n","    on=\"timestamp\",\n","    how=\"inner\"\n",")\n","\n","df = df.sort_values(\"timestamp\").reset_index(drop=True)\n","\n","print(\"=\" * 55)\n","print(\"MERGED DATASET\")\n","print(\"=\" * 55)\n","print(f\"Rows:     {len(df)}\")\n","print(f\"Columns:  {list(df.columns)}\")\n","print(f\"Range:    {df['timestamp'].min()} → {df['timestamp'].max()}\")\n","print(f\"\\nMissing values:\\n{df.isnull().sum()}\")\n","print(f\"\\nSample:\\n{df.head()}\")\n","print(f\"\\nBy season:\\n{df.groupby('season')[['price_eur_mwh','wind_total_mw','load_mw']].describe().round(1).to_string()}\")\n","\n","df.to_csv(\"combined_dataset.csv\", index=False)\n","print(\"\\n✓ Saved to combined_dataset.csv\")\n","\n","# ─────────────────────────────────────────────\n","# Plot — one figure per season, 3 subplots each\n","# ─────────────────────────────────────────────\n","seasons = [\"2022/23\", \"2023/24\", \"2024/25\"]\n","labels  = [\"2022/23 (Training)\", \"2023/24 (Training)\", \"2024/25 (Test)\"]\n","colours = {\"price_eur_mwh\": \"#E8453C\", \"wind_total_mw\": \"#4A90D9\", \"load_mw\": \"#F5A623\"}\n","\n","for season, label in zip(seasons, labels):\n","    subset = df[df[\"season\"] == season].copy()\n","\n","    fig, axes = plt.subplots(3, 1, figsize=(14, 10), sharex=True)\n","    fig.suptitle(f\"Winter {label}\", fontsize=15, fontweight=\"bold\", y=0.98)\n","\n","    # Day-ahead price\n","    axes[0].plot(subset[\"timestamp\"], subset[\"price_eur_mwh\"],\n","                 color=colours[\"price_eur_mwh\"], linewidth=0.6, alpha=0.85)\n","    axes[0].set_ylabel(\"Price (€/MWh)\", fontsize=10)\n","    axes[0].set_title(\"Day-Ahead Price\", fontsize=10, pad=4)\n","    axes[0].axhline(0, color=\"black\", linewidth=0.5, linestyle=\"--\", alpha=0.4)\n","    axes[0].grid(True, alpha=0.3)\n","\n","    # Wind total\n","    axes[1].plot(subset[\"timestamp\"], subset[\"wind_total_mw\"],\n","                 color=colours[\"wind_total_mw\"], linewidth=0.6, alpha=0.85)\n","    axes[1].set_ylabel(\"Wind (MW)\", fontsize=10)\n","    axes[1].set_title(\"Total Wind Generation (Onshore + Offshore)\", fontsize=10, pad=4)\n","    axes[1].grid(True, alpha=0.3)\n","\n","    # Load\n","    axes[2].plot(subset[\"timestamp\